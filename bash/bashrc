apostrophe() {
    flatpak run org.gnome.gitlab.somas.Apostrophe "$@" & disown
}

snapback() {
    if [ -z "$1" ]; then
        echo "Usage: snapback \"description here\""
        return 1
    fi
    sudo snapper -c root create --description "$1"
    echo "Snapshot created: $1"
}

snaplist() {
    sudo snapper -c root list
}

snapback_rollback() {
    if [ -z "$1" ]; then
        echo "Usage: snapback_rollback <snapshot-number>"
        snaplist
        return 1
    fi
    sudo snapper -c root rollback "$1"
    echo "Rolled back to snapshot $1 — reboot to complete."
}

