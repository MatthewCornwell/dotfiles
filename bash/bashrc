# .bashrc

# Source global definitions
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# User specific environment
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]; then
    PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi
export PATH

# Uncomment the following line if you don't like systemctl's auto-paging feature:
# export SYSTEMD_PAGER=

# User specific aliases and functions
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        if [ -f "$rc" ]; then
            . "$rc"
        fi
    done
fi

# --- Hyprland / config editing ---
alias hyprconf='micro ~/.config/hypr/hyprland.lua'
alias hyprreload='hyprctl reload; killall waybar; waybar & disown'
alias waybarconf='micro ~/.config/waybar/style.css'
alias waybarr='killall waybar; waybar & disown'
alias kittyconf='micro ~/.config/kitty/kitty.conf'
alias woficonf='micro ~/.config/wofi/style.css'
alias bashrc='micro ~/.bashrc'
alias bashrcs='source ~/.bashrc'
alias m='micro'
alias temp='cd ~/temp'
alias tempr='rm ~/temp/*'

# --- Wallpaper control ---
alias wallnext='pkill -f wallpaper-rotate; ~/.local/bin/wallpaper-rotate.sh > /tmp/wallpaper-rotate.log 2>&1 &'
alias wallstop='pkill -f wallpaper-rotate'
alias wallconf='micro ~/.local/bin/wallpaper-rotate.sh'

# --- Dotfiles management ---
alias dotcd='cd ~/dotfiles'
alias dotpush='cd ~/dotfiles && git add -A && git commit -m "update $(date +%Y-%m-%d_%H:%M)" && git push'
alias dotpull='cd ~/dotfiles && git pull'
alias dotstatus='cd ~/dotfiles && git status'

